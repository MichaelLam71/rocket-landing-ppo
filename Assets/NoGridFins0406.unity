    - target: {fileID: -3261592592775887085, guid: f6879a39bb77c48acac1d47e9709e4c1, type: 3}
      propertyPath: m_Name
      value: 'using UnityEngine; using UnityEngine.InputSystem;  [RequireComponent(typeof(Rigidbody))]
        public class RocketController : MonoBehaviour {     [Header("Engine Reference")]    
        [Tooltip("Drag your engine outlet mesh Transform here.")]     public Transform
        engineOutlet;      [Header("Thrust Settings (Newtons)")]     public float
        seaLevelThrust = 7607000f;     public float vacuumThrust = 8227000f;    
        public float vacuumAltitude = 80000f;      [Header("Rocket Mass")]     public
        float rocketMass = 450000f;      [Header("Gravity")]     public float g0
        = 9.807f;     public float earthRadius = 6371000f;     public float seaLevelY
        = 0f;      [Header("Debug")]     public bool showThrustRay = true;      private
        Rigidbody rb;     private bool engineOn = false;     private float currentThrust
        = 0f;     private float currentG = 0f;      void Start()     {         rb
        = GetComponent<Rigidbody>();         rb.mass = rocketMass;         rb.useGravity
        = false;         rb.linearDamping = 0f;         rb.angularDamping = 0.05f;         
        if (engineOutlet == null)         {             Debug.LogError("engineOutlet
        is NOT assigned!");         }         else         {             Debug.Log("Engine
        outlet found: " + engineOutlet.name);         }     }      void Update()    
        {         HandleInput();     }      void FixedUpdate()     {         ApplyGravity();        
        ApplyThrust();     }      void HandleInput()     {         if (Keyboard.current.spaceKey.wasPressedThisFrame)        
        {             engineOn = !engineOn;             Debug.Log("Engines: " + (engineOn
        ? "ON" : "OFF"));         }     }      void ApplyGravity()     {        
        float h = GetAltitude();         float ratio = earthRadius / (earthRadius
        + h);         currentG = g0 * ratio * ratio;         rb.AddForce(Vector3.down
        * rb.mass * currentG, ForceMode.Force);     }      void ApplyThrust()    
        {         if (engineOutlet == null) return;          if (engineOn)        
        {             float altitude = GetAltitude();             currentThrust =
        GetThrustAtAltitude(altitude);              Vector3 thrustDir = engineOutlet.up;            
        Vector3 thrustForce = thrustDir * currentThrust;              rb.AddForceAtPosition(thrustForce,
        engineOutlet.position, ForceMode.Force);              if (showThrustRay)            
        {                 Debug.DrawRay(engineOutlet.position, thrustDir * 25f, Color.red);            
        }         }         else         {             currentThrust = 0f;        
        }     }      float GetAltitude()     {         return Mathf.Max(0f, transform.position.y
        - seaLevelY);     }      float GetThrustAtAltitude(float altitude)     {        
        float t = Mathf.Clamp01(altitude / vacuumAltitude);         return Mathf.Lerp(seaLevelThrust,
        vacuumThrust, t);     }      void OnGUI()     {         if (rb == null) return;         
        float altitude = GetAltitude();         float speedMs = rb.linearVelocity.magnitude;        
        float verticalSpd = rb.linearVelocity.y;         float thrustKN = currentThrust
        / 1000f;         float twr = 0f;          if (currentG > 0f)         {            
        twr = currentThrust / (rb.mass * currentG);         }          string engineStatus;        
        if (engineOn)         {             engineStatus = "ON  [SPACE to off]";        
        }         else         {             engineStatus = "OFF [SPACE to on]";        
        }          string altStr = (altitude / 1000f).ToString("F2") + " km";        
        string speedStr = speedMs.ToString("F1") + " m/s";         string vertStr
        = verticalSpd.ToString("F1") + " m/s";         string gravStr = currentG.ToString("F4")
        + " m/s2";         string thrustStr = thrustKN.ToString("F1") + " kN";        
        string twrStr = twr.ToString("F3");          GUI.Box(new Rect(8, 8, 280,
        190), "");         GUILayout.BeginArea(new Rect(14, 14, 268, 180));        
        GUILayout.Label("ROCKET TELEMETRY");         GUILayout.Space(4);        
        GUILayout.Label("Altitude     : " + altStr);         GUILayout.Label("Speed       
        : " + speedStr);         GUILayout.Label("Vertical Spd : " + vertStr);        
        GUILayout.Label("Gravity      : " + gravStr);         GUILayout.Label("Thrust      
        : " + thrustStr);         GUILayout.Label("TWR          : " + twrStr);        
        GUILayout.Label("Engines      : " + engineStatus);         GUILayout.EndArea();    
        } }'
      objectReference: {fileID: 0}
